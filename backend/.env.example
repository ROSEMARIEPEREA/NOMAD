# Copy this file to .env before running

PORT=4000
JWT_SECRET=change_this_to_something_random

# DB_DIALECT=sqlite -> zero setup, uses a local file (default, recommended for demo)
# DB_DIALECT=mysql  -> matches the manuscript's stack; requires a running MySQL server
DB_DIALECT=sqlite
SQLITE_PATH=./data/nomad.sqlite

# Only used if DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_NAME=nomad
DB_USER=root
DB_PASS=

# Restrict signup to a company email domain. Leave blank (default) to allow
# any email domain -- this is the setting we use in the demo, since not
# every organization has its own custom domain (e.g. small teams on Gmail).
# The real "verification" requirement is enforced by OTP, not domain
# matching -- set this per-deployment if a specific organization DOES want
# to lock signup to their own domain, e.g. ALLOWED_EMAIL_DOMAIN=acmecorp.com
ALLOWED_EMAIL_DOMAIN=
