# Dependencies -- these are huge and regenerated by `npm install`,
# never commit them
node_modules/

# Environment/secrets -- contains things like JWT_SECRET, DB passwords.
# Each person running the project should have their own .env, copied
# from .env.example (which IS safe to commit, since it has no real secrets)
.env

# Database file -- this is generated data (demo accounts, cards, messages),
# not source code. Everyone who runs the project generates their own via
# `npm run seed`
backend/data/
*.sqlite

# Build output -- regenerated by `npm run build`, not source code
frontend/dist/

# Editor/OS clutter
.DS_Store
Thumbs.db
.vscode/
*.log
